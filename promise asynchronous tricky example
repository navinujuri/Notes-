console.log("1: start");

async function asyncFunc() {
  console.log("2: asyncFunc start");
  await null; // yields to microtask queue
  console.log("5: asyncFunc after await");
}

setTimeout(() => {
  console.log("7: setTimeout callback");
}, 0);

asyncFunc();

Promise.resolve().then(() => {
  console.log("6: promise.then");
});

console.log("3: sync code end");

queueMicrotask(() => {
  console.log("4: queueMicrotask");
});

1: start
2: asyncFunc start
3: sync code end
5: asyncFunc after await
6: promise.then
4: queueMicrotask
7: setTimeout callback



